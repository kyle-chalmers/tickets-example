# Internal-only (public-repo hygiene): owner config + notes, never published.
.internal/

# OS / editor
.DS_Store
*.swp
*~
.idea/
*.iml

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env

# ── Ticketwright ─────────────────────────────────────────────────────────────
# Ticket exports are customer data → they go to the docstore (Drive/SharePoint), NOT git.
# Anchored with **/ so it matches at ANY depth (tickets/<assignee>/<id>/final_deliverables/) —
# an un-anchored rule would silently commit every nested export, the exact PII leak this prevents.
**/final_deliverables/*.csv
**/final_deliverables/*.tsv
**/final_deliverables/*.xlsx
**/final_deliverables/*.parquet
# Deliverable SQL, QC SQL, and READMEs are reviewable artifacts — those stay committed.

# Downloaded attachments are inputs you didn't author and often carry PII. Uncomment to enforce
# (you can still `git add -f` a specific small input you mean to track):
# **/source_materials/*
# !**/source_materials/.gitkeep

# Per-user / per-install (never shared); the team-shared .claude/settings.json IS committed.
.claude/settings.local.json
.claude/worktrees/
